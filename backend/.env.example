# Backend Machines App - .env.example
#
# NOTE:
# - Questo file contiene placeholder generici.
# - Usa il tuo .env reale sul server di produzione (Ubuntu).

# Server
NODE_ENV=production
PORT=3001
LOG_LEVEL=info

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/mydb

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change_me_super_secret
JWT_REFRESH_SECRET=change_me_super_refresh_secret
JWT_EXPIRY=24h
JWT_REFRESH_EXPIRY=7d

# CORS
CORS_ORIGIN=http://localhost:5173

# AI (Ollama/tagger service)
AI_PROVIDER=ollama
AI_API_URL=http://localhost:11434
AI_MODEL=llama2
AI_TIMEOUT=30000

# LDAP (opzionale)
LDAP_ENABLED=false
LDAP_SERVER=
LDAP_BASE_DN=

