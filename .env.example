# Database
DB_USER=machines_user
DB_PASSWORD=change_me_secure_password
DATABASE_URL=postgres://machines_user:change_me_secure_password@postgres:5432/machines_db

# Redis
REDIS_URL=redis://redis:6379

# JWT
JWT_SECRET=change_me_jwt_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars
JWT_EXPIRY=24h
JWT_REFRESH_EXPIRY=7d

# Server
PORT=3001
NODE_ENV=production
LOG_LEVEL=info
CORS_ORIGIN=http://localhost

# AI (Ollama) — in Docker usare il nome servizio "ollama" (non il container_name)
AI_PROVIDER=ollama
AI_API_URL=http://ollama:11434
AI_MODEL=llama3.1:8b
AI_TIMEOUT=120000

# Dopo il primo avvio, scarica il modello (deve corrispondere ad AI_MODEL):
#   chmod +x scripts/setup-ollama.sh && ./scripts/setup-ollama.sh
# oppure manualmente:
#   docker exec machines_ollama ollama pull llama3.1:8b

# LDAP (optional)
LDAP_ENABLED=false
LDAP_SERVER=
LDAP_BASE_DN=
